# Turn Rewrite Engine On
RewriteEngine on

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ── Applicants ──
RewriteRule ^applicants(/*)$ index.php?request=applicants [L,QSA]
RewriteRule ^applicants/new(/*)$ index.php?request=newapplicant [L,QSA]
RewriteRule ^applicants/edit/([0-9]+)(/*)$ index.php?request=editapplicant&id=$1 [L,QSA]
RewriteRule ^applicants/page/([0-9]+)(/*)$ index.php?request=applicants&page=$1 [L,QSA]
RewriteRule ^applicants/page(/*)$ index.php?request=applicants&page=$1 [L,QSA]

# ── Users ──
RewriteRule ^usr/new(/*)$ index.php?request=newuser [L,QSA]
RewriteRule ^usr/edit/([0-9]+)(/*)$ index.php?request=edituser&id=$1 [L,QSA]
RewriteRule ^usr/page/([0-9]+)(/*)$ index.php?request=users&page=$1 [L,QSA]
RewriteRule ^usr/page(/*)$ index.php?request=users&page=$1 [L,QSA]
RewriteRule ^usr/([0-9]+)(/*)$ index.php?request=user&ID=$1 [L,QSA]
RewriteRule ^usr(/*)$ index.php?request=user [L,QSA]

# ── Project ──
RewriteRule ^project/([a-z]+)(/*)$ index.php?request=project&trunk=$1 [L,QSA]

# ── Messager ──
RewriteRule ^msg/page/([0-9]+)(/*)$ index.php?request=messager&page=$1 [L,QSA]
RewriteRule ^msg/page(/*)$ index.php?request=messager&page=$1 [L,QSA]
RewriteRule ^msg/([0-9]+)(/*)$ index.php?request=messager&ID=$1 [L,QSA]
RewriteRule ^msg(/*)$ index.php?request=messager [L,QSA]

# ── Notes ──
RewriteRule ^notes(/*)$ index.php?request=notes [L,QSA]

# ── Export ──
RewriteRule ^export/([0-9]+)(/*)$ export.php?id=$1 [L,QSA]
RewriteRule ^exportsearch(/*)$ exportsearch.php [L,QSA]

# ── Players ──
RewriteRule ^players/search/([0-9a-zA-Z_-]+)(/*)$ players.php?search=$1 [L,QSA]
RewriteRule ^players/search(/*)$ players.php?search=$1 [L,QSA]
RewriteRule ^players/subpage/([a-zA-Z_-]+)(/*)$ players.php?subpage=$1 [L,QSA]
RewriteRule ^players/([0-9]+)/([0-9a-zA-Z_-]+)(/*)$ players.php?id=$1&action=$2 [L,QSA]
RewriteRule ^players/([0-9]+)(/*)$ players.php?id=$1 [L,QSA]

# ── Events ──
RewriteRule ^events/new(/*)$ index.php?request=newevent [L,QSA]
RewriteRule ^events/edit/([0-9]+)(/*)$ index.php?request=editevent&id=$1 [L,QSA]
RewriteRule ^events/page/([0-9]+)(/*)$ index.php?request=events&page=$1 [L,QSA]
RewriteRule ^events/page(/*)$ index.php?request=events&page=$1 [L,QSA]
RewriteRule ^events/([0-9]+)/([0-9a-zA-Z_-]+)(/*)$ index.php?request=event&id=$1&menu=$2 [L,QSA]
RewriteRule ^events/([0-9]+)(/*)$ index.php?request=event&id=$1 [L,QSA]
RewriteRule ^events(/*)$ index.php?request=events [L,QSA]

# ── Printer ──
RewriteRule ^printer/([0-9]+)(/*)$ index.php?request=printer&id=$1 [L,QSA]
RewriteRule ^printer(/*)$ index.php?request=printer [L,QSA]

# ── Company ──
RewriteRule ^company/([a-z]+)/([0-9]+)/([a-z-]+)(/*)$ index.php?request=company&trunk=$1&id=$2&branch=$3 [L,QSA]
RewriteRule ^company/([a-z]+)/([a-z]+)(/*)$ index.php?request=company&trunk=$1&branch=$2 [L,QSA]
RewriteRule ^company/([a-z]+)(/*)$ index.php?request=company&trunk=$1 [L,QSA]
RewriteRule ^company/([0-9]+)(/*)$ index.php?request=company&ID=$1 [L,QSA]
RewriteRule ^company(/*)$ index.php?request=company [L,QSA]

# ── Report ──
RewriteRule ^app/report/([a-z]+)(/*)$ index.php?request=app&trunk=report&branch=$1 [L,QSA]

# ── Serie Package ──
RewriteRule ^app/serie-package/([a-z]+)/([0-9]+)(/*)$ index.php?request=app&trunk=serie-package&branch=$1&package_id=$2 [L,QSA]
RewriteRule ^app/serie-package/([a-z]+)(/*)$ index.php?request=app&trunk=serie-package&branch=$1 [L,QSA]

# ── Serie Episode Slide ──
RewriteRule ^app/serie-episode-slide/([0-9]+)/([a-z]+)/([0-9]+)(/*)$ index.php?request=app&trunk=serie-episode-slide&episode_id=$1&branch=$2&slide_id=$3 [L,QSA]
RewriteRule ^app/serie-episode-slide/([0-9]+)/([a-z]+)(/*)$ index.php?request=app&trunk=serie-episode-slide&episode_id=$1&branch=$2 [L,QSA]

# ── Serie Episode ──
RewriteRule ^app/serie-episode/([0-9]+)/([a-z]+)/([0-9]+)(/*)$ index.php?request=app&trunk=serie-episode&serie_id=$1&branch=$2&episode_id=$3 [L,QSA]
RewriteRule ^app/serie-episode/([0-9]+)/([a-z]+)(/*)$ index.php?request=app&trunk=serie-episode&serie_id=$1&branch=$2 [L,QSA]

# ── Emploi (must come before generic app rules) ──
RewriteRule ^app/emploi/([a-z]+)/([0-9]+)(/*)$ index.php?request=app&trunk=emploi&branch=$1&serie_id=$2 [L,QSA]
RewriteRule ^app/emploi/([a-z]+)(/*)$ index.php?request=app&trunk=emploi&branch=$1 [L,QSA]

# ── Serie ──
RewriteRule ^app/serie/([a-z]+)/([0-9]+)(/*)$ index.php?request=app&trunk=serie&serie_id=$2&branch=$1 [L,QSA]
RewriteRule ^app/serie/([a-z]+)(/*)$ index.php?request=app&trunk=serie&branch=$1 [L,QSA]

# ── Apps (generic — must come last among app/* rules) ──
RewriteRule ^apps(/*)$ index.php?request=app [L,QSA]
RewriteRule ^app/([a-z-]+)/([0-9]+)(/*)$ index.php?request=app&idname=Ikizere&trunk=home&id=5&branch=$1&iditem=$2 [L,QSA]
RewriteRule ^app/([a-z-]+)(/*)$ index.php?request=app&idname=Ikizere&trunk=home&id=5&branch=$1 [L,QSA]
RewriteRule ^app/([a-z]+)(/*)$ index.php?request=app&idname=Ikizere&trunk=$1 [L,QSA]
RewriteRule ^app/([a-zA-Z0-9]+)(/*)$ index.php?request=app&idname=$1 [L,QSA]

# ── Signup / Login ──
RewriteRule ^signup(/*)$ signup.php [L,QSA]
RewriteRule ^login/([a-z]+)/([0-9]+)/([0-9A-Z]+)(/*)$ login.php?request=$1&id=$2&code=$3 [L,QSA]
RewriteRule ^login/([a-z]+)/([0-9A-Z]+)(/*)$ login.php?request=$1&response=$2 [L,QSA]
RewriteRule ^login/([a-z]+)/([a-z]+)(/*)$ login.php?request=$1&response=$2 [L,QSA]
RewriteRule ^login/([a-z]+)(/*)$ login.php?request=$1 [L,QSA]
RewriteRule ^login(/*)$ login.php?request=login [L,QSA]

# ── Global fallback (must be last) ──
RewriteRule ^([a-z]+)(/*)$ index.php?request=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]